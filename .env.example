# Lex-Gov AI — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key (₹1,000 credits) at https://dashboard.sarvam.ai
SARVAM_API_KEY=your-sarvam-api-key-here

# ── Security ──────────────────────────────────────────────────────────────────
# Change this to a long random string in any deployment
SECRET_KEY=change-this-in-production-to-a-random-string

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@db:5432/lexgov
